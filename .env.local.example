# Supabase (new project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only. Required for the admin portal (read-as) and the seed script.
# NEVER expose this to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI (doubt solver / quiz / planner / career)
NVIDIA_API_KEY=your-nvidia-api-key

# Password used for all seeded demo accounts (students/teacher/parents). Optional.
SEED_DEMO_PASSWORD=Afsk@2027
# Admin demo login created by the seed script. Optional (defaults shown).
SEED_ADMIN_EMAIL=admin@afsk.edu
SEED_ADMIN_PASSWORD=AfskAdmin@2027
